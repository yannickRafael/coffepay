# CoffePay — environment template. Copy to .env and fill real values.
# .env is gitignored; .env.example is committed.

# ----- Postgres (docker-compose: ops/docker-compose.yml) -----
POSTGRES_USER=coffepay
POSTGRES_PASSWORD=coffepay
POSTGRES_DB=coffepay
POSTGRES_PORT=5432
DATABASE_URL=postgresql://coffepay:coffepay@localhost:5432/coffepay?schema=public

# ----- Redis (queues / cache / session-key) -----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- Auth / crypto -----
JWT_SECRET=change-me-dev-only
WEBHOOK_SIGNING_SECRET=change-me-dev-only

# ----- M-Pesa (Vodacom Moçambique OpenAPI) -----
# RSA public key used to encrypt the API key into a Bearer session token (~1h).
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_API_HOST=https://api.sandbox.vm.co.mz
MPESA_SERVICE_PROVIDER_CODE=171717
MPESA_ORIGIN_COUNTRY=MZ
MPESA_CURRENCY=MZN

# ----- FX (MZN <-> USD) -----
FX_BASE_CURRENCY=MZN
FX_QUOTE_CURRENCY=USD
FX_SPREAD_PCT=2.5
FX_RATE_TTL_SECONDS=900
FX_PROVIDER_URL=

# ----- Service ports (local dev) -----
API_GATEWAY_PORT=3000
SESSION_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
CALLBACK_SERVICE_PORT=3003
KYC_SERVICE_PORT=3004
FX_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
MOCKSTORE_PORT=4000

# ----- Misc -----
NODE_ENV=development
LOG_LEVEL=debug
