{
  "name": "coffepay",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway de interoperabilidade para carteiras móveis e pagamentos internacionais",
  "author": "Yannick Rafael Alberto Matimbe",
  "license": "UNLICENSED",
  "workspaces": [
    "services/*",
    "packages/*",
    "mockstore"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}
