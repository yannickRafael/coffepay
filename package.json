{
  "name": "coffepay",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway de interoperabilidade para carteiras móveis e pagamentos internacionais",
  "author": "Yannick Rafael Alberto Matimbe",
  "license": "UNLICENSED",
  "workspaces": [
    "services/*",
    "packages/*",
    "mockstore"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && npm run clean --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "prisma generate --schema=packages/shared/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/shared/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=packages/shared/prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --schema=packages/shared/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/shared/prisma/schema.prisma",
    "mpesa:smoke": "tsx --env-file=.env packages/shared/scripts/mpesa-session-smoke.ts",
    "mpesa:c2b": "tsx --env-file=.env packages/shared/scripts/mpesa-c2b-smoke.ts"
  },
  "prisma": {
    "seed": "tsx packages/shared/prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}
